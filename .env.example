# Firebase Configuration
# Copy this file to .env and fill in your values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App Settings
VITE_APP_NAME=Miplace Premium

# Credenciais de Acesso
# Formato preferido: PBKDF2 — gere com hashPassword() do utils.js e cole o resultado (começa com "pbkdf2:")
# Formato legado aceito: SHA-256 de 64 chars hex — gere com: echo -n "SUASENHA" | sha256sum
VITE_ADM_NAME=Nome do Administrador
VITE_ADM_HASH=pbkdf2:your_salt_hex:your_hash_hex
VITE_HASH_GABRIELA=pbkdf2:your_salt_hex:your_hash_hex
VITE_HASH_SABRINA=pbkdf2:your_salt_hex:your_hash_hex
VITE_MANAGER_HASH=pbkdf2:your_salt_hex:your_hash_hex