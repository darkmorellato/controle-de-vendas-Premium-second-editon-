rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: check if user is admin ──────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ─── Helper: check if user is manager ────────────────────────────────
    function isManager() {
      return request.auth != null &&
        request.auth.token.manager == true;
    }

    // ─── Helper: check if employeeName matches the logged-in user ─────────
    function isOwner(employeeName) {
      return request.auth != null &&
        (isAdmin() || isManager() || request.auth.token.employeeName == employeeName);
    }

    // ─── Vendas ───────────────────────────────────────────────────────
    match /vendas/{saleId} {
      // Employees see only their own sales; admins/managers see all
      allow read: if request.auth != null &&
        (isAdmin() || isManager() ||
         resource.data.employeeName == request.auth.token.employeeName);

      // Allow create only for authenticated users with valid fields
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['id', 'date', 'employeeName', 'category', 'items', 'amount'])
        && request.resource.data.id == saleId
        && request.resource.data.employeeName is string
        && request.resource.data.employeeName == request.auth.token.employeeName
        && request.resource.data.amount is number;

      // Allow update: owner or admin/manager only, cannot change saleId
      allow update: if request.auth != null
        && request.resource.data.id == saleId
        && (isAdmin() || isManager() ||
            resource.data.employeeName == request.auth.token.employeeName);

      // Only admins can delete sales
      allow delete: if isAdmin();
    }

    // ─── Clientes ─────────────────────────────────────────────────────
    match /clientes/{clientId} {
      // All authenticated users can read clients (needed for client lookup across employees)
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['id', 'name'])
        && request.resource.data.id == clientId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update: if request.auth != null
        && request.resource.data.id == clientId;

      allow delete: if isAdmin();
    }

    // ─── Contratos (PDFs em base64) ──────────────────────────────────
    match /contratos/{contractId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['saleId', 'fileName', 'contentType'])
        && request.resource.data.contentType == 'application/pdf'
        && request.resource.data.base64Data.size() <= 1400000;

      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Rotina State ────────────────────────────────────────────────
    match /rotina_state/{date} {
      allow read: if request.auth != null;

      // Only allow updates to today's routine state
      // Firestore Rules uses timestamp.date() for date comparison
      allow write: if request.auth != null
        && date == string(request.time.year) + '-' +
             string(request.time.month).padStart(2, '0') + '-' +
             string(request.time.day).padStart(2, '0');
    }

    // ─── System Logs ─────────────────────────────────────────────────
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['action', 'user', 'timestamp']);
      allow update, delete: if false;
    }

    // ─── Deny all other collections by default ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
